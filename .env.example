# Secret key — generate with:" python -c "import secrets; print(secrets.token_hex(32))" "
PA_SECRET_KEY=change-in-production

# Database — SQLite (dev) or PostgreSQL (production)
# Leave commented for SQLite (zero setup required locally)
# DATABASE_URL=postgresql://pa_user:pa_pass@localhost:5432/pa_validation

# FastAPI server
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=true

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# PostgreSQL connection pool
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30